# Copy to .env.local for local development.

# Kokoro-FastAPI OpenAI-compatible speech endpoint.
# Default in the app: http://127.0.0.1:8880
KOKORO_BASE_URL=http://127.0.0.1:8880

# Optional bearer token if your Kokoro deployment requires auth.
KOKORO_API_KEY=

# Default speech request payload values used by src/server/pi/kokoro.ts.
KOKORO_MODEL=kokoro
KOKORO_VOICE=af_bella

# Optional pi host configuration.
# The app embeds pi sessions and reads auth/models from the host machine.
# Default pi storage location: ~/.pi/agent
PI_CODING_AGENT_DIR=

# Optional provider API keys for pi model availability.
# Only set the providers you actually use. These are alternatives to `pi`
# + `/login`; if auth.json already contains working credentials, they are not
# required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
